{
  "name": "mac-2d-hamster-pet",
  "version": "0.1.0",
  "description": "A tiny 2D desktop hamster pet prototype.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "optimize:assets": "scripts/optimize-assets.sh",
    "pack": "electron-builder --dir",
    "dist:mac": "electron-builder --mac zip",
    "dist:win": "electron-builder --win nsis",
    "dist:win:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.codex.hamsterpet",
    "productName": "Hamster Pet",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "src/**/*",
      "assets/hamster-optimized/**/*",
      "!**/.DS_Store"
    ],
    "mac": {
      "target": "zip"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
